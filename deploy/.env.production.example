APP_DOMAIN=about-plan.example.com

POSTGRES_DB=about_plan
POSTGRES_USER=about_plan
POSTGRES_PASSWORD=please_change_this_password

# 최소 32자 이상 랜덤 문자열 권장
JWT_SECRET=please_change_this_jwt_secret_to_long_random_string

# 브라우저에서 백엔드 호출 시 사용할 공개 URL
# 같은 도메인에서 /api로 리버스 프록시하므로 도메인 루트를 넣으면 됩니다.
NEXT_PUBLIC_API_BASE_URL=https://about-plan.example.com

# SecurityConfig 의 CORS 허용 도메인
APP_CORS_ALLOWED_ORIGINS=https://about-plan.example.com
